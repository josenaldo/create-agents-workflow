{
  "label": "Python + uv",
  "hint": "FastAPI, Flask, Django, etc. (uv package manager)",
  "kind": "base",
  "commands": {
    "dev": "uv run python -m app",
    "build": "uv build",
    "test:unit": "uv run pytest tests/unit -x",
    "test:integration": "uv run pytest tests/integration -x",
    "test:e2e": "uv run pytest tests/e2e -x",
    "lint": "uv run ruff check .",
    "format": "uv run ruff format .",
    "typecheck": "uv run mypy .",
    "deps:install": "uv sync",
    "deps:add": "uv add"
  },
  "layout": "src/{module}/{domain,application,infrastructure}",
  "testFramework": "pytest"
}
